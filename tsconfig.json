{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "moduleResolution": "node"
  },
  "include": ["./hardhat.config.ts", "./scripts/**/*.ts", "./test/**/*.ts", "./ignition/**/*.ts"],
  "exclude": ["node_modules", "frontend"]
}
